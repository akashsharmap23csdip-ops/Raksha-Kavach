<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_gradient">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/incident_title"
            android:textColor="@color/safety_white"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textIncidentDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/safety_orange" />

        <EditText
            android:id="@+id/inputIncidentTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_input"
            android:hint="Incident Title"
            android:padding="12dp"
            android:textColor="@color/safety_white"
            android:textColorHint="@color/safety_orange" />

        <EditText
            android:id="@+id/inputIncidentDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input"
            android:hint="Description"
            android:minLines="3"
            android:padding="12dp"
            android:textColor="@color/safety_white"
            android:textColorHint="@color/safety_orange" />

        <ImageView
            android:id="@+id/imagePreview"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_card"
            android:contentDescription="@string/incident_title" />

        <Button
            android:id="@+id/btnPickImage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_button_outline"
            android:text="Add Image"
            android:textColor="@color/safety_white" />

        <Button
            android:id="@+id/btnSubmitIncident"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_button_primary"
            android:text="Submit Incident"
            android:textColor="@color/safety_black"
            android:textStyle="bold" />
    </LinearLayout>
</ScrollView>
